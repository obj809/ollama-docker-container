# Copy to .env and adjust as needed: cp .env.example .env

# Host port to expose the Ollama API on (container always listens on 11434).
OLLAMA_PORT=11434

# Space-separated list of models pulled when the container starts.
# Browse models at https://ollama.com/library
PULL_MODELS=llama3.2:1b deepseek-r1:1.5b

# How long a model stays loaded in memory after the last request
# (e.g. 30s, 10m, 24h; -1 = keep loaded indefinitely).
OLLAMA_KEEP_ALIVE=24h
